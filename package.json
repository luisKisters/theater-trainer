{
  "name": "theater-trainer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sirv-cli . --port 9123 --cors --single",
    "serve": "sirv-cli . --port 9123 --cors --single",
    "test:unit": "node --test $(find tests/unit -name '*.test.js' | sort)",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "sirv-cli": "^2.0.2"
  }
}
